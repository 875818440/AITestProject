# ==================================================
# 社交媒体账号风险预警系统 — 环境变量配置示例
# 复制为 .env 并填写真实值
# ==================================================

# ---- 应用基础配置 ----
APP_NAME="Social Media Risk Warning System"
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- JWT 配置 ----
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=risk_warning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/risk_warning

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- 风险评分配置 ----
RISK_THRESHOLD_LOW=31
RISK_THRESHOLD_MEDIUM=61
RISK_THRESHOLD_HIGH=81
ALERT_DEDUP_WINDOW_SECONDS=300     # 5 分钟内同用户不重复告警
FEATURE_SEQUENCE_LENGTH=20         # LSTM 输入时序窗口长度

# ---- LSTM 模型 ----
MODEL_PATH=./ml_training/models
MODEL_VERSION=v1

# ---- IP 地理位置 ----
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb

# ---- 邮件告警 ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourapp.com
SMTP_FROM_NAME="安全预警系统"

# ---- 短信告警（阿里云） ----
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sign-name
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxxx

# ---- Firebase FCM 推送 ----
FCM_SERVER_KEY=your-fcm-server-key
FCM_API_URL=https://fcm.googleapis.com/fcm/send

# ---- Prometheus 监控 ----
METRICS_ENABLED=true
